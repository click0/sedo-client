{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    ".git/**",
    "node_modules/**",
    "downloads/**",
    ".pytest_cache/**",
    "*.der",
    "*.bin",
    "*.sig",
    "*.cer",
    "*.zip"
  ],
  "ignoreRegExpList": [
    "[\\p{Script=Cyrillic}\\u0400-\\u04FF]+",
    "0x[0-9a-fA-F]+",
    "[A-Z_]{3,}",
    "https?://\\S+",
    "\\\\\\\\[a-zA-Z0-9_]+"
  ],
  "words": [
    "almaz",
    "ansible",
    "avcryptoki",
    "cades",
    "cipher",
    "ccid",
    "codespell",
    "cpkcs",
    "cspell",
    "cspextension",
    "cspbase",
    "dstu",
    "dstucrypt",
    "edrpou",
    "efitkey",
    "eusign",
    "eusigncp",
    "eusignrpc",
    "evrozhnak",
    "fiddler",
    "gryada",
    "iitcom",
    "jkurwa",
    "jcpkcs",
    "kalyna",
    "kupyna",
    "libccid",
    "libpcsclite",
    "muromec",
    "ncmgryada",
    "ncmhost",
    "nchostcp",
    "pcsc",
    "pcscd",
    "pinentry",
    "pkcs",
    "plcpkcs",
    "prodan",
    "pykcs",
    "pykcslib",
    "scard",
    "scardsvr",
    "securetoken",
    "sedo",
    "smoketest",
    "sysowcw",
    "syswow",
    "tellipse",
    "tspaddress",
    "unzr",
    "winreg",
    "winrm",
    "xades",
    "zsu"
  ],
  "flagWords": [],
  "allowCompoundWords": true
}
